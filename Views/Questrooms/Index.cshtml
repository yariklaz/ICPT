@model IEnumerable<QuestBooking.Domain.Model.Questroom>

@{
    ViewData["Title"] = "Список квестів";
    // Підключаємо стандартний шаблон зі стилями
    Layout = "_Layout";
}

<div class="container mt-4">
    <h1 class="display-4 text-center">Список квест-кімнат</h1>

    <p class="mt-4">
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle"></i> Створити новий квест
        </a>
    </p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Title)</th>
                        <th>@Html.DisplayNameFor(model => model.MaxPlayers)</th>
                        <th>@Html.DisplayNameFor(model => model.BasePrice)</th>
                        <th>@Html.DisplayNameFor(model => model.DurationMinutes)</th>
                        <th class="text-center">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle fw-bold">
                                @Html.DisplayFor(modelItem => item.Title)
                            </td>
                            <td class="align-middle">
                                @Html.DisplayFor(modelItem => item.MaxPlayers) гравців
                            </td>
                            <td class="align-middle">
                                @Html.DisplayFor(modelItem => item.BasePrice) грн
                            </td>
                            <td class="align-middle">
                                @Html.DisplayFor(modelItem => item.DurationMinutes) хв
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редагувати</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Деталі</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>